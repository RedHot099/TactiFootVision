# Copy this file to `run_config/test_soccernet_tracking.env` and edit the values
# before running the SoccerNet tracking integration test.

# Absolute path to the `img1` folder containing extracted SoccerNet frames.
SOCCERNET_TRACKING_SEQUENCE_DIR="/abs/path/to/SoccerNet/match_xxx/img1"

# Detection model selection: yolo | rfdetr | rfdetr_seg
TACTIFOOT_TEST_MODEL_TYPE="rfdetr_seg"

# Path to the checkpoint/weights file matching the model type.
# When using rfdetr_seg, the repository ships with `rf-detr-seg-preview.pt`.
TACTIFOOT_TEST_CHECKPOINT="/abs/path/to/rf-detr-seg-preview.pt"

# Optional overrides (uncomment to customize)
#TACTIFOOT_TEST_MAX_FRAMES=60          # Limits processed frames (default: 40)
#TACTIFOOT_TEST_CONFIDENCE=0.35        # Detection confidence threshold (default: 0.3)
#TACTIFOOT_TEST_NMS=0.5                # NMS threshold (default: 0.5)
#TACTIFOOT_TEST_INCLUDE_LABELS="player,goalkeeper"
#TACTIFOOT_TEST_OUTPUT_DIR="/abs/path/to/results/soccernet_tracking"
